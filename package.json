{
  "name": "not-sure-hockey",
  "version": "1.0.0",
  "description": "Website for the Not Sure hockey teams (Kraken Hockey League).",
  "type": "module",
  "private": true,
  "scripts": {
    "build:teams": "node scripts/build-teams.mjs",
    "fetch:schedule": "node scripts/fetch-schedule.mjs",
    "fetch:standings": "node scripts/fetch-standings.mjs",
    "fetch:stats": "node scripts/fetch-stats.mjs",
    "fetch:attendance": "node scripts/fetch-attendance.mjs",
    "fetch:roster": "node scripts/fetch-roster.mjs",
    "benchapp:login": "node scripts/fetch-attendance.mjs --login",
    "benchapp:debug": "node scripts/fetch-attendance.mjs --debug",
    "fetch:all": "npm run build:teams && npm run fetch:schedule && npm run fetch:standings && npm run fetch:stats && npm run fetch:attendance && npm run fetch:roster",
    "serve": "node scripts/serve.mjs"
  },
  "dependencies": {
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "playwright": "^1.49.0"
  }
}
